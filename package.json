{
    "name": "vulnpilot-ai",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:web": "npm run dev --workspace apps/web",
        "dev:api": "npm run start:dev --workspace apps/api",
        "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
        "test": "npm run test --workspaces --if-present"
    },
    "devDependencies": {
        "typescript": "^5.6.3",
        "ts-node": "^10.9.2",
        "jest": "^29.7.0",
        "@types/node": "^22.10.1"
    }
}
