generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  projects  Project[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  projects       Project[]
  scans          ScanRun[]
  createdAt      DateTime     @default(now())
}

model Project {
  id             String       @id @default(cuid())
  name           String
  repositoryUrl  String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ownerId        String?
  owner          User?        @relation(fields: [ownerId], references: [id])
  repositories   Repository[]
  scans          ScanRun[]
  createdAt      DateTime     @default(now())
}

model Repository {
  id          String     @id @default(cuid())
  name        String
  provider    String
  url         String
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  scanRuns    ScanRun[]
  createdAt   DateTime   @default(now())
}

model ScanRun {
  id                String               @id @default(cuid())
  status            String
  repositoryId      String
  repository        Repository           @relation(fields: [repositoryId], references: [id])
  projectId         String
  project           Project              @relation(fields: [projectId], references: [id])
  initiatedById     String?
  initiatedBy       User?                @relation(fields: [initiatedById], references: [id])
  findings          VulnerabilityFinding[]
  patchSuggestions  PatchSuggestion[]
  reports           Report[]
  createdAt         DateTime             @default(now())
}

model VulnerabilityFinding {
  id           String     @id @default(cuid())
  title        String
  severity     String
  ruleId       String
  language     String
  snippet      String
  recommendation String
  cwe          String?
  owasp        String?
  scanRunId    String
  scanRun      ScanRun    @relation(fields: [scanRunId], references: [id])
  createdAt    DateTime   @default(now())
}

model PatchSuggestion {
  id           String   @id @default(cuid())
  summary      String
  diff         String
  commitMessage String
  pullRequestDescription String
  scanRunId    String
  scanRun      ScanRun  @relation(fields: [scanRunId], references: [id])
  createdAt    DateTime @default(now())
}

model Report {
  id            String   @id @default(cuid())
  type          String
  format        String
  content       String
  scanRunId     String
  scanRun       ScanRun  @relation(fields: [scanRunId], references: [id])
  createdAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actor       String
  action      String
  detail      String?
  createdAt   DateTime @default(now())
}
